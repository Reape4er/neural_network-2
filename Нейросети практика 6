        "callbacks = [\n",
        "    # Сохраняем модель каждую эпоху\n",
        "    ModelCheckpoint(\n",
        "        filepath=os.path.join(model_dir, \"model_epoch_{epoch:02d}_{loss:.5f}.h5\"),\n",
        "        save_best_only=True,  # Сохраняем только лучшую модель\n",
        "        monitor=\"val_loss\",   # Отслеживаем val_loss\n",
        "        verbose=1\n",
        "    ),\n",
        "\n",
        "    # Останавливаем обучение, если val_loss не улучшается 5 эпох\n",
        "    EarlyStopping(\n",
        "        monitor=\"val_loss\",\n",
        "        patience=5,\n",
        "        restore_best_weights=True,  # Возвращаем лучшие веса\n",
        "        verbose=1\n",
        "    ),\n",
        "\n",
        "    # Уменьшаем learning rate, если val_loss не улучшается 3 эпохи\n",
        "    ReduceLROnPlateau(\n",
        "        monitor=\"val_loss\",\n",
        "        factor=0.1,  # Уменьшаем LR в 10 раз\n",
        "        patience=2,\n",
        "        verbose=1\n",
        "    )\n",
        "]\n",
        "\n"

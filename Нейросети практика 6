        "from tensorflow.keras.callbacks import ModelCheckpoint,EarlyStopping,ReduceLROnPlateau\n",
        "import os\n",
        "# Пути для сохранения модели и логов\n",
        "model_dir = \"./drive/My Drive/models\"\n",

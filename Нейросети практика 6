        "img_height = 224\n",
        "img_width = 224\n",
        "batch_size = 32\n",
        "\n",
        "train_ds = tf.keras.utils.image_dataset_from_directory(\n",
        "  path_train,\n",
        "  seed=123,\n",
        "  image_size=(img_height, img_width),\n",
        "  batch_size=batch_size,\n",
        "  label_mode=None\n",
        "  )\n",
        "\n",
        "val_ds = tf.keras.utils.image_dataset_from_directory(\n",
        "  path_val,\n",
        "  seed=123,\n",
        "  image_size=(img_height, img_width),\n",
        "  batch_size=batch_size,\n",
        "  label_mode=None )\n",
        "\n",
        "import tensorflow as tf\n",
        "import tensorflow_io as tfio\n",
        "\n",
        "def rgb_to_lab(image):\n",
        "    \"\"\"Конвертирует RGB-изображение в LAB и разделяет на L и AB.\"\"\"\n",
        "    image = image / 255.0\n",
        "    lab = tfio.experimental.color.rgb_to_lab(image)\n",
        "    ab_channels = lab[..., 1:] / 128.0\n",
        "    l_channel=preprocess_input(lab[..., :1]) #* 2.55\n",
        "    l_channel_3d = tf.repeat(l_channel, repeats=3, axis=-1)\n",
        "    print(l_channel_3d.shape)\n",
        "    return l_channel_3d, ab_channels\n",
        "\n",
        "# Применение к датасету\n",
        "train_ds_lab = (\n",
        "    train_ds\n",
        "    .map(rgb_to_lab, num_parallel_calls=tf.data.AUTOTUNE)  # Параллельная обработка\n",
        "    # .cache('./train_cache')               # Кэшируем после преобразований\n",
        "    .prefetch(tf.data.AUTOTUNE)\n",
        ")\n",
        "val_ds_lab = (\n",

      "source": [
        "from tensorflow.keras import layers, Model\n",
        "from tensorflow.keras.optimizers import Adam\n",
        "from keras.applications import ResNet50V2\n",
        "\n",
        "import numpy as np\n",
        "import tensorflow as tf\n",
        "from tensorflow.keras.applications import ResNet50V2\n",
        "from tensorflow.keras.models import Model\n",
        "\n",
        "# Загружаем предобученный энкодер\n",
        "encoder = ResNet50V2(weights=\"imagenet\", include_top=False, input_shape=(224, 224, 3))\n",
        "encoder.trainable = False\n",
        "\n",
        "x = layers.Conv2DTranspose(256, 3, strides=2, padding='same')(encoder.output)\n",
        "x = layers.ReLU()(x)\n",
        "x = layers.Conv2DTranspose(128, 3, strides=2, padding='same')(x)\n",
        "x = layers.ReLU()(x)\n",
        "x = layers.Conv2DTranspose(64, 3, strides=2, padding='same')(x)\n",
        "x = layers.ReLU()(x)\n",
        "x = layers.Conv2DTranspose(32, 3, strides=2, padding='same')(x)\n",
        "x = layers.ReLU()(x)\n",
        "outputs = layers.Conv2DTranspose(2, 3, strides=2, padding='same', activation='tanh')(x)\n",
        "\n",
        "model = Model(encoder.input, outputs)\n",
        "\n"
      ]

        "import tensorflow as tf\n",
        "import gradio as gr\n",
        "import cv2 as cv\n",
        "import numpy as np\n",
        "from keras.applications.resnet_v2 import preprocess_input\n",
        "\n",
        "\n",
        "# Функция для предобработки изображения\n",
        "def preprocess_image(image):\n",
        "    l_channel=preprocess_input(cv.resize(image,(224,224))) #* 2.55\n",
        "    image_3channels = np.repeat(l_channel[..., np.newaxis], 3, axis=-1)\n",
        "    # Добавление размерности batch (None, 224, 224, 3)\n",
        "    image_batch = np.expand_dims(image_3channels, axis=0)\n",
        "    # Теперь image_batch имеет форму (1, 224, 224, 3)\n",
        "    image_tensor = tf.convert_to_tensor(image_batch, dtype=tf.float32)\n",
        "    print(l_channel.shape)\n",
        "    print(np.max(l_channel))\n",
        "    print(np.min(l_channel))\n",
        "    return image_tensor\n",
        "\n",
        "# Функция для обработки изображения\n",
        "def process_image(image, preprocessed_image):\n",
        "    l_channel = cv.resize(image,(224,224))/2.55\n",
        "\n",
        "    ab_channels_norm = model.predict(preprocessed_image)[0]\n",
        "\n",
        "    ab_channels = ab_channels_norm * 128\n",
        "\n",
        "    # 1. Расширяем L-канал до формы (224, 224, 1)\n",
        "    l_channel_expanded = np.expand_dims(l_channel, axis=-1)\n",
        "    image = np.concatenate([l_channel_expanded, ab_channels], axis=-1)\n",
        "    num_channels = image.shape[-1]  # Количество каналов\n",
        "    for channel in range(num_channels):\n",
        "        channel_data = image[..., channel]  # Выбираем данные по каналу\n",
        "        print(f\"\\nChannel {channel}:\")\n",
        "        print(\"Min value:\", np.min(channel_data))\n",
        "        print(\"Max value:\", np.max(channel_data))\n",
        "        print(\"Mean value:\", np.mean(channel_data))\n",
        "        print(\"Standard deviation:\", np.std(channel_data))\n",
        "        print(\"First few values:\", channel_data.flatten()[:10])  # Первые 10 значений\n",
        "    # Преобразование LAB в RGB\n",
        "    rgb_image = cv2.cvtColor(image.astype(np.float32), cv2.COLOR_LAB2RGB)\n",
        "    return rgb_image\n",
        "\n",
        "# Функция, которая будет вызываться Gradio\n",
        "def predict(image):\n",
        "    # Предобработка изображения\n",
        "    preprocessed_image = preprocess_image(image)\n",
        "\n",
        "    # Обработка изображения\n",
        "    processed_image = process_image(image, preprocessed_image)\n",
        "\n",
        "    # Возвращаем обработанное изображение\n",
        "    return processed_image\n",
        "\n",
        "# Создание Gradio интерфейса\n",
        "iface = gr.Interface(\n",
        "    fn=predict,  # Функция, которая будет вызываться\n",
        "    inputs=gr.Image(label=\"Входное изображение\",image_mode=\"L\"),  # Входной интерфейс для изображения\n",
        "    outputs=gr.Image(label=\"Обработанное изображение\", image_mode=\"RGB\"),  # Выходной интерфейс для изображения\n",
        "    title=\"Обработка изображений\",  # Заголовок интерфейса\n",
        "    description=\"Загрузите изображение, чтобы увидеть результат обработки.\",  # Описание интерфейса\n",
        "    )\n",
        "\n",
        "# Запуск интерфейса\n",
        "iface.launch(debug=True)"
